document.addEventListener('DOMContentLoaded', () => {
    
    // Função para o botão ler mais
    const botoesLeitura = document.querySelectorAll('.btn-leia-mais');
    botoesLeitura.forEach((botao) => {
        botao.addEventListener('click', () => {
            alert('Portas abertas! O artigo completo está sendo preparado para o próximo lote de atualizações.');
        });
    });

    // Sistema Funcional de Dark Mode (Modo Escuro)
    const btnDarkMode = document.getElementById('toggle-dark-mode');
    const body = document.body;

    btnDarkMode.addEventListener('click', () => {
        body.classList.toggle('dark-theme');
        
        // Altera o emoji do botão dependendo do tema ativo
        if (body.classList.contains('dark-theme')) {
            btnDarkMode.textContent = '☀️ Modo Claro';
        } else {
            btnDarkMode.textContent = '🌙 Modo Escuro';
        }
    });
});
